# ============================================================
# Yoko & Yoshi — environment variables (template)
# Copy to .env.local and fill in. Never commit .env.local.
# ============================================================

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- SUPABASE -----
# From your Supabase project settings: Project URL, anon/public, service_role
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...
# Project ref (used by `pnpm db:types`)
SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# ----- UPSTASH REDIS (rate limiting) -----
# Free tier: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- ALLEGRO API (sync products + click tracking metadata) -----
# OAuth2 device flow — register an app at developer.allegro.pl
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# ----- ON-DEMAND REVALIDATION -----
# Shared secret for /api/revalidate endpoint
REVALIDATE_TOKEN=replace-with-strong-random-token

# ----- LOGGING -----
LOG_LEVEL=debug

# ----- ANALYTICS -----
# Plausible (cookieless, GDPR-friendly). Leave blank to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ----- SENTRY (optional) -----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
